# ─── Logoviking Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — add it to .gitignore

# ── AI Provider Keys (at least one required) ───────────────────────────────────
# Get Anthropic key → https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=

# Get OpenAI key → https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=

# ── Site ────────────────────────────────────────────────────────────────────────
VITE_SITE_URL=https://logoviking.com
NODE_ENV=production

# ── Analytics (optional) ────────────────────────────────────────────────────────
VITE_GA_MEASUREMENT_ID=

# ── AdSense (optional — add after approval) ─────────────────────────────────────
# Get from: https://www.google.com/adsense → Sites → ads.txt
VITE_ADSENSE_PUBLISHER_ID=

# ── Stripe (optional — for real payments, Phase 2) ──────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=

# ── Google OAuth (optional — for real login, Phase 2) ───────────────────────────
VITE_GOOGLE_CLIENT_ID=
